{
  "name": "hass-odps",
  "version": "1.0.25",
  "private": true,
  "scripts": {
    "build": "npm run build:client && tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint . && tsc --noEmit",
